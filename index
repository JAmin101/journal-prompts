<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Journal Prompt Picker</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Lora:ital,wght@0,400;0,500;1,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --cream: #f5f0e8; --ink: #2c2416; --ink-light: #5a4e38;
    --ink-faint: #9c8e76; --gold: #c8973a; --gold-light: #e8c06a;
    --rust: #b5532a; --sage: #5a7a5e; --card-bg: #faf7f2; --border: #d8cdb8;
  }
  body {
    background: var(--cream); font-family: 'Lora', serif; color: var(--ink); min-height: 100vh;
    background-image:
      radial-gradient(ellipse at 20% 50%, rgba(200,151,58,0.07) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, rgba(90,122,94,0.05) 0%, transparent 50%);
  }
  .app { max-width: 760px; margin: 0 auto; padding: 48px 24px 80px; }

  .header { text-align: center; margin-bottom: 52px; }
  .eyebrow { font-family: 'DM Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); margin-bottom: 14px; }
  h1 { font-family: 'Playfair Display', serif; font-size: clamp(2rem,5vw,3rem); font-weight: 400; line-height: 1.15; margin-bottom: 14px; }
  h1 em { font-style: italic; color: var(--gold); }
  .tagline { font-size: 0.95rem; color: var(--ink-light); line-height: 1.7; max-width: 460px; margin: 0 auto; }

  .card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 4px; padding: 28px 32px; margin-bottom: 24px; position: relative; overflow: hidden; }
  .card::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: linear-gradient(to bottom, var(--gold), var(--gold-light)); }
  .card h3 { font-family: 'Playfair Display', serif; font-weight: 600; font-size: 1.05rem; margin-bottom: 8px; }
  .card-desc { font-size: 0.83rem; color: var(--ink-faint); line-height: 1.6; margin-bottom: 16px; }
  .toggle-link { color: var(--gold); cursor: pointer; text-decoration: underline; }

  .instructions { background: rgba(200,151,58,0.06); border: 1px dashed var(--gold-light); border-radius: 4px; padding: 18px 22px; margin-bottom: 16px; font-size: 0.82rem; line-height: 1.85; color: var(--ink-light); display: none; }
  .instructions.open { display: block; }
  .inst-title { font-family: 'DM Mono', monospace; font-size: 0.74rem; letter-spacing: 0.1em; color: var(--gold); margin-bottom: 10px; display: block; }
  .instructions ol { padding-left: 18px; }
  .instructions li { margin-bottom: 3px; }
  .instructions code { font-family: 'DM Mono', monospace; background: rgba(200,151,58,0.12); padding: 1px 5px; border-radius: 2px; font-size: 0.85em; color: var(--ink); }

  .input-row { display: flex; gap: 10px; }
  .sheet-input { flex: 1; padding: 10px 14px; border: 1px solid var(--border); border-radius: 3px; background: white; font-family: 'DM Mono', monospace; font-size: 0.78rem; color: var(--ink); outline: none; transition: border-color 0.2s; }
  .sheet-input:focus { border-color: var(--gold); }
  .sheet-input::placeholder { color: var(--ink-faint); }
  .btn-load { padding: 10px 20px; background: var(--ink); color: var(--cream); border: none; border-radius: 3px; font-family: 'DM Mono', monospace; font-size: 0.78rem; letter-spacing: 0.08em; cursor: pointer; transition: background 0.2s; white-space: nowrap; }
  .btn-load:hover { background: var(--ink-light); }
  .btn-load:disabled { opacity: 0.55; cursor: not-allowed; }

  .status { display: none; align-items: center; gap: 6px; font-family: 'DM Mono', monospace; font-size: 0.75rem; margin-top: 10px; padding: 5px 12px; border-radius: 20px; letter-spacing: 0.05em; width: fit-content; }
  .status.show { display: inline-flex; }
  .status.success { background: rgba(90,122,94,0.12); color: var(--sage); }
  .status.error   { background: rgba(181,83,42,0.10); color: var(--rust); }
  .status.loading { background: rgba(200,151,58,0.10); color: var(--gold); }
  .sdot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; animation: pulse 1.5s ease-in-out infinite; }
  .status.success .sdot, .status.error .sdot { animation: none; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

  .err-box { display: none; margin-top: 10px; padding: 12px 16px; background: rgba(181,83,42,0.07); border: 1px solid rgba(181,83,42,0.2); border-radius: 3px; font-size: 0.8rem; color: var(--rust); line-height: 1.7; }
  .err-box.show { display: block; }
  .err-box b { display: block; margin-bottom: 6px; }
  .err-box ul { padding-left: 16px; }
  .err-box li { margin-bottom: 3px; }

  .main-ui { display: none; }
  .main-ui.show { display: block; }

  .controls { margin-bottom: 36px; display: flex; flex-direction: column; gap: 26px; }
  .ctrl-label { font-family: 'DM Mono', monospace; font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-faint); display: block; margin-bottom: 12px; }
  .pills { display: flex; flex-wrap: wrap; gap: 8px; }
  .pill { padding: 7px 16px; border-radius: 30px; font-family: 'Lora', serif; font-size: 0.85rem; cursor: pointer; border: 1px solid var(--border); background: transparent; color: var(--ink-light); transition: all 0.2s; }
  .pill:hover { border-color: var(--gold); color: var(--gold); }
  .pill.active { background: var(--ink); border-color: var(--ink); color: var(--cream); }

  .count-row { display: flex; gap: 10px; }
  .cnt-btn { width: 48px; height: 48px; border-radius: 50%; border: 1px solid var(--border); background: transparent; font-family: 'Playfair Display', serif; font-size: 1.2rem; color: var(--ink-light); cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; }
  .cnt-btn:hover { border-color: var(--gold); color: var(--gold); }
  .cnt-btn.active { background: var(--gold); border-color: var(--gold); color: white; }

  .bank-info { font-family: 'DM Mono', monospace; font-size: 0.72rem; color: var(--ink-faint); text-align: center; margin-bottom: 28px; letter-spacing: 0.08em; }
  .bank-info span { color: var(--gold); font-weight: 500; }

  .pick-wrap { display: flex; justify-content: center; margin-bottom: 44px; }
  .pick-btn { position: relative; padding: 18px 52px; background: transparent; border: 2px solid var(--ink); color: var(--ink); font-family: 'Playfair Display', serif; font-size: 1.05rem; font-style: italic; cursor: pointer; overflow: hidden; transition: color 0.25s; }
  .pick-btn::before { content: ''; position: absolute; inset: 0; background: var(--ink); transform: translateY(100%); transition: transform 0.25s ease; z-index: 0; }
  .pick-btn:hover::before { transform: translateY(0); }
  .pick-btn:hover { color: var(--cream); }
  .pick-btn:active { transform: scale(0.98); }
  .pick-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .pick-btn:disabled:hover { color: var(--ink); }
  .pick-btn:disabled::before { transform: translateY(100%); }
  .pick-label { position: relative; z-index: 1; }

  .prompt-cards { display: flex; flex-direction: column; gap: 16px; }
  .prompt-card { background: var(--card-bg); border: 1px solid var(--border); padding: 30px 34px; border-radius: 4px; position: relative; overflow: hidden; animation: cardIn 0.4s cubic-bezier(0.22,1,0.36,1) both; }
  .prompt-card:nth-child(2) { animation-delay: 0.08s; }
  .prompt-card:nth-child(3) { animation-delay: 0.16s; }
  @keyframes cardIn { from{opacity:0;transform:translateY(18px)} to{opacity:1;transform:translateY(0)} }
  .card-accent { position: absolute; top: 0; left: 0; right: 0; height: 2px; }
  .card-num { font-family: 'DM Mono', monospace; font-size: 0.68rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-faint); margin-bottom: 14px; }
  .card-text { font-family: 'Playfair Display', serif; font-size: clamp(1.05rem,2.5vw,1.22rem); line-height: 1.65; font-style: italic; }
  .card-tag { display: inline-block; margin-top: 16px; font-family: 'DM Mono', monospace; font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; padding: 3px 10px; border-radius: 2px; }

  .empty { text-align: center; padding: 60px 24px; color: var(--ink-faint); }
  .empty-icon { font-size: 44px; margin-bottom: 14px; opacity: 0.45; }
  .empty p { font-style: italic; font-size: 0.95rem; line-height: 1.6; }

  .progress-log { font-family: 'DM Mono', monospace; font-size: 0.72rem; color: var(--ink-faint); margin-top: 8px; line-height: 1.7; display: none; }
  .progress-log.show { display: block; }
</style>
</head>
<body>
<div class="app">

  <div class="header">
    <div class="eyebrow">&#10022; Daily Reflection &#10022;</div>
    <h1>Your <em>Journal</em> Prompts</h1>
    <p class="tagline">Connect your Google Sheet, choose a theme, and let serendipity guide your pen.</p>
  </div>

  <div class="card">
    <h3>&#128196; Connect your Google Sheet</h3>
    <p class="card-desc">
      Paste your Google Sheet URL. Sheet must have two columns: <strong>Category</strong> and <strong>Prompt</strong>.
      The sheet must be shared as <strong>Anyone with the link &rarr; Viewer</strong>.
      <span class="toggle-link" id="toggleLink" onclick="toggleInst()"> Show setup guide &darr;</span>
      &nbsp;&middot;&nbsp;
      <span class="toggle-link" onclick="forgetSheet()" title="Clear saved URL">Forget saved sheet</span>
    </p>

    <div class="instructions" id="inst">
      <span class="inst-title">&#10022; HOW TO SET UP YOUR SHEET</span>
      <ol>
        <li>Create a new Google Sheet.</li>
        <li>Row 1: Column A = <code>Category</code>, Column B = <code>Prompt</code></li>
        <li>Add your prompts below, e.g. <code>Career</code> | <code>What does success mean to me?</code></li>
        <li>Click <strong>Share</strong> &rarr; change to <strong>Anyone with the link</strong> &rarr; role: <strong>Viewer</strong> &rarr; click Done.</li>
        <li>Copy the URL from your browser and paste it below.</li>
        <li>Hit <strong>Load</strong>. Add/remove prompts anytime &mdash; just reload to refresh.</li>
      </ol>
    </div>

    <div class="input-row">
      <input class="sheet-input" id="sheetUrl" placeholder="https://docs.google.com/spreadsheets/d/&hellip;" />
      <button class="btn-load" id="loadBtn" onclick="loadSheet()">Load</button>
    </div>

    <div class="status" id="status">
      <span class="sdot"></span>
      <span id="statusMsg"></span>
    </div>
    <div class="progress-log" id="progressLog"></div>
    <div class="err-box" id="errBox">
      <b>How to fix this:</b>
      <ul id="errList"></ul>
    </div>
  </div>

  <div class="main-ui" id="mainUI">
    <div class="controls">
      <div>
        <span class="ctrl-label">Filter by category</span>
        <div class="pills" id="pills"></div>
      </div>
      <div>
        <span class="ctrl-label">How many prompts?</span>
        <div class="count-row" id="countRow"></div>
      </div>
    </div>

    <div class="bank-info" id="bankInfo"></div>

    <div class="pick-wrap">
      <button class="pick-btn" id="pickBtn" onclick="pickPrompts()">
        <span class="pick-label" id="pickLabel">Pick a Prompt &#10022;</span>
      </button>
    </div>

    <div class="prompt-cards" id="cards"></div>
  </div>

  <div class="empty" id="emptyState">
    <div class="empty-icon">&#10022;</div>
    <p>Connect your Google Sheet above<br>to start drawing prompts for your journal.</p>
  </div>

</div>
<script>
// ── State ───────────────────────────────────────────────────────────────────
var allPrompts  = [];
var categories  = [];
var selectedCat = 'All';
var pickCount   = 1;

var CAT_COLORS = {
  career:        { accent:'#4a6882', tag:'rgba(74,104,130,0.12)',  text:'#4a6882' },
  money:         { accent:'#5a7a5e', tag:'rgba(90,122,94,0.12)',   text:'#5a7a5e' },
  relationships: { accent:'#7a6a8a', tag:'rgba(122,106,138,0.12)', text:'#7a6a8a' },
  health:        { accent:'#b5532a', tag:'rgba(181,83,42,0.12)',   text:'#b5532a' },
  mindset:       { accent:'#c8973a', tag:'rgba(200,151,58,0.12)',  text:'#a87a20' },
  creativity:    { accent:'#8a5a72', tag:'rgba(138,90,114,0.12)', text:'#8a5a72' },
  gratitude:     { accent:'#6a8a6a', tag:'rgba(106,138,106,0.12)',text:'#4a7a4a' },
  def:           { accent:'#9c8e76', tag:'rgba(156,142,118,0.12)',text:'#6a5e4a' }
};
function catStyle(cat){ return CAT_COLORS[(cat||'').toLowerCase().trim()] || CAT_COLORS.def; }
function esc(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

// ── Instructions ─────────────────────────────────────────────────────────────
function toggleInst(){
  var el = document.getElementById('inst');
  var lk = document.getElementById('toggleLink');
  el.classList.toggle('open');
  lk.innerHTML = el.classList.contains('open') ? ' Hide setup guide &uarr;' : ' Show setup guide &darr;';
}

// ── Sheet ID ─────────────────────────────────────────────────────────────────
function extractId(url){
  var m = url.trim().match(/\/spreadsheets\/d\/([a-zA-Z0-9-_]+)/);
  if(m) return m[1];
  if(/^[a-zA-Z0-9-_]{20,}$/.test(url.trim())) return url.trim();
  return null;
}

// ── Progress log ──────────────────────────────────────────────────────────────
function log(msg){
  var el = document.getElementById('progressLog');
  el.classList.add('show');
  el.innerHTML += msg + '<br>';
}
function clearLog(){
  var el = document.getElementById('progressLog');
  el.classList.remove('show');
  el.innerHTML = '';
}

// ── Fetch strategies ──────────────────────────────────────────────────────────
async function tryFetch(url, label){
  log('Trying: ' + label + '...');
  try {
    var res = await fetch(url, { signal: AbortSignal.timeout(10000) });
    if(!res.ok){ log('&nbsp;&nbsp;&rarr; HTTP ' + res.status); return null; }
    var text = await res.text();
    if(!text || text.length < 5){ log('&nbsp;&nbsp;&rarr; Empty response'); return null; }
    if(text.trim().startsWith('<!') || text.trim().startsWith('<html')){ log('&nbsp;&nbsp;&rarr; Got HTML (not CSV/JSON)'); return null; }
    log('&nbsp;&nbsp;&rarr; <strong>Success!</strong>');
    return { text: text, url: url };
  } catch(e){
    log('&nbsp;&nbsp;&rarr; Failed (' + (e.message||'timeout') + ')');
    return null;
  }
}

async function loadAllStrategies(id){
  var sheetName = 'Sheet1'; // default sheet name

  // Strategy 1: opensheet.elk.sh (returns JSON, no CORS)
  var r = await tryFetch(
    'https://opensheet.elk.sh/' + id + '/1',
    'opensheet.elk.sh (JSON API)'
  );
  if(r) return { type:'json', data: r.text };

  // Strategy 2: opensheet with sheet name
  r = await tryFetch(
    'https://opensheet.elk.sh/' + id + '/' + sheetName,
    'opensheet.elk.sh / Sheet1'
  );
  if(r) return { type:'json', data: r.text };

  // Strategy 3: Published CSV via corsproxy
  var csvExport = 'https://docs.google.com/spreadsheets/d/' + id + '/export?format=csv&gid=0';
  r = await tryFetch(
    'https://corsproxy.io/?url=' + encodeURIComponent(csvExport),
    'corsproxy.io + CSV export'
  );
  if(r) return { type:'csv', data: r.text };

  // Strategy 4: pub CSV via corsproxy
  var csvPub = 'https://docs.google.com/spreadsheets/d/' + id + '/pub?output=csv';
  r = await tryFetch(
    'https://corsproxy.io/?url=' + encodeURIComponent(csvPub),
    'corsproxy.io + pub CSV'
  );
  if(r) return { type:'csv', data: r.text };

  // Strategy 5: allorigins
  r = await tryFetch(
    'https://api.allorigins.win/raw?url=' + encodeURIComponent(csvExport),
    'allorigins.win + CSV export'
  );
  if(r) return { type:'csv', data: r.text };

  // Strategy 6: allorigins pub
  r = await tryFetch(
    'https://api.allorigins.win/raw?url=' + encodeURIComponent(csvPub),
    'allorigins.win + pub CSV'
  );
  if(r) return { type:'csv', data: r.text };

  return null;
}

// ── Parse JSON from opensheet ─────────────────────────────────────────────────
function parseJSON(text){
  try {
    var rows = JSON.parse(text);
    if(!Array.isArray(rows) || rows.length === 0) return [];
    var out = [];
    rows.forEach(function(row){
      // Find prompt and category keys case-insensitively
      var promptKey = Object.keys(row).find(function(k){ return ['prompt','prompts','question','entry'].indexOf(k.toLowerCase().trim()) > -1; });
      var catKey    = Object.keys(row).find(function(k){ return ['category','cat','type','theme'].indexOf(k.toLowerCase().trim()) > -1; });
      var prompt   = promptKey ? (row[promptKey]||'').replace(/^\s+|\s+$/g,'') : '';
      var category = catKey   ? (row[catKey]   ||'General').trim() : 'General';
      if(prompt) out.push({ prompt: prompt, category: category });
    });
    return out;
  } catch(e){ return null; }
}

// ── Parse CSV (multiline-aware) ───────────────────────────────────────────────
// Parses the full CSV text as a character stream so that quoted cells
// containing Alt+Enter (\n) line breaks are handled correctly.
function parseCSVFull(text){
  var rows=[], row=[], cur='', inQ=false;
  // Normalise line endings
  var s = text.replace(/\r\n/g,'\n').replace(/\r/g,'\n');
  for(var i=0;i<s.length;i++){
    var c=s[i];
    if(c==='"'){
      if(inQ && s[i+1]==='"'){cur+='"';i++;} // escaped quote ""
      else{inQ=!inQ;}
    } else if(c===',' && !inQ){
      row.push(cur); cur='';
    } else if(c==='\n' && !inQ){
      row.push(cur); cur='';
      rows.push(row); row=[];
    } else {
      cur+=c;
    }
  }
  // Push last cell/row
  row.push(cur);
  if(row.some(function(x){return x.trim()!=='';})) rows.push(row);

  if(rows.length<2) return [];

  var header=rows[0].map(function(h){return h.trim().toLowerCase().replace(/[^a-z]/g,'');});
  var catIdx=-1,promptIdx=-1;
  for(var i=0;i<header.length;i++){
    if(['category','cat','type','theme'].indexOf(header[i])>-1) catIdx=i;
    if(['prompt','prompts','question','entry'].indexOf(header[i])>-1) promptIdx=i;
  }
  if(promptIdx===-1) return null;

  var out=[];
  for(var r=1;r<rows.length;r++){
    var ro=rows[r];
    var prompt=(ro[promptIdx]||'').trim();
    var cat=catIdx>=0?(ro[catIdx]||'General').trim():'General';
    if(prompt) out.push({prompt:prompt,category:cat});
  }
  return out;
}

// Keep old name as alias
function parseCSV(text){ return parseCSVFull(text); }

// ── Markdown renderer ─────────────────────────────────────────────────────────
// Supports: **bold**, *italic*, soft line breaks (\n → <br>)
// Use this instead of esc() for prompt text.
function renderMarkdown(str){
  // 1. Escape HTML first
  var s = str
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;');
  // 2. Bold: **text**
  s = s.replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>');
  // 3. Italic: *text* (but not inside bold)
  s = s.replace(/\*([^*\n]+?)\*/g,'<em>$1</em>');
  // 4. Soft line breaks (Alt+Enter in Sheets stores as \n)
  s = s.replace(/\n/g,'<br>');
  return s;
}

// ── Load sheet ────────────────────────────────────────────────────────────────
async function loadSheet(){
  var url = document.getElementById('sheetUrl').value.trim();
  var id  = extractId(url);

  clearLog();
  document.getElementById('errBox').classList.remove('show');

  if(!id){
    setStatus('error','Could not find a Sheet ID in that URL.');
    showErr(['Paste the full Google Sheets URL, e.g. https://docs.google.com/spreadsheets/d/ABC123.../edit']);
    return;
  }

  setStatus('loading','Connecting to your sheet&hellip;');
  document.getElementById('loadBtn').disabled = true;

  var result = await loadAllStrategies(id);
  document.getElementById('loadBtn').disabled = false;

  if(!result){
    setStatus('error','Could not load your sheet after trying all methods.');
    showErr([
      'Make sure the sheet is shared: click <strong>Share</strong> &rarr; <strong>Anyone with the link</strong> &rarr; Viewer &rarr; Done',
      'Double-check the URL is correct',
      'Try opening the link in an incognito window &mdash; if it prompts you to log in, it is not public enough'
    ]);
    return;
  }

  var parsed;
  if(result.type === 'json'){
    parsed = parseJSON(result.data);
  } else {
    parsed = parseCSV(result.data);
  }

  if(parsed === null){
    setStatus('error','Sheet loaded but column headers not recognised.');
    showErr([
      'Row 1 must have a column called <strong>Category</strong> and a column called <strong>Prompt</strong>',
      'Check for typos or extra spaces in those header cells'
    ]);
    return;
  }

  if(parsed.length === 0){
    setStatus('error','No prompts found in the sheet.');
    showErr([
      'Make sure you have data rows below the header row',
      'Check the Prompt column is not empty'
    ]);
    return;
  }

  allPrompts  = parsed;
  selectedCat = 'All';
  pickCount   = 1;
  categories  = ['All'].concat(
    parsed.map(function(p){return p.category;})
      .filter(function(v,i,a){return a.indexOf(v)===i&&v;})
  );

  // Save URL so it reloads automatically next time
  try { localStorage.setItem('journal_sheet_url', url); } catch(e){}

  clearLog();
  setStatus('success', parsed.length + ' prompt' + (parsed.length!==1?'s':'') + ' loaded \u2713');
  document.getElementById('emptyState').style.display = 'none';
  renderUI();
  document.getElementById('mainUI').classList.add('show');
}

function setStatus(type, msg){
  var el=document.getElementById('status');
  el.className='status show '+type;
  document.getElementById('statusMsg').innerHTML=msg;
}

function showErr(tips){
  var el=document.getElementById('errBox');
  document.getElementById('errList').innerHTML=tips.map(function(t){return '<li>'+t+'</li>';}).join('');
  el.classList.add('show');
}

// ── Render UI ─────────────────────────────────────────────────────────────────
function renderUI(){ renderPills(); renderCountBtns(); updateBank(); updatePickBtn(); document.getElementById('cards').innerHTML=''; }

function renderPills(){
  var c=document.getElementById('pills');
  c.innerHTML='';
  categories.forEach(function(cat){
    var b=document.createElement('button');
    b.className='pill'+(cat===selectedCat?' active':'');
    b.textContent=cat;
    b.onclick=function(){selectedCat=cat;renderPills();updateBank();updatePickBtn();document.getElementById('cards').innerHTML='';};
    c.appendChild(b);
  });
}

function renderCountBtns(){
  var c=document.getElementById('countRow');
  c.innerHTML='';
  [1,2,3].forEach(function(n){
    var b=document.createElement('button');
    b.className='cnt-btn'+(n===pickCount?' active':'');
    b.textContent=n;
    b.onclick=function(){pickCount=n;renderCountBtns();updatePickBtn();document.getElementById('cards').innerHTML='';};
    c.appendChild(b);
  });
}

function pool(){
  if(selectedCat==='All') return allPrompts;
  return allPrompts.filter(function(p){return p.category.toLowerCase()===selectedCat.toLowerCase();});
}

function updateBank(){
  var p=pool();
  document.getElementById('bankInfo').innerHTML='<span>'+p.length+'</span> prompt'+(p.length!==1?'s':'')+' in '+(selectedCat==='All'?'your bank':selectedCat);
}

function updatePickBtn(){
  var p=pool();
  var btn=document.getElementById('pickBtn');
  btn.disabled=p.length===0;
  var hasCards=document.getElementById('cards').children.length>0;
  document.getElementById('pickLabel').textContent=hasCards?'Pick Again \u21BB':(pickCount===1?'Pick a Prompt \u2726':'Pick '+pickCount+' Prompts \u2726');
}

function pickPrompts(){
  var p=pool();
  if(!p.length) return;
  var picked=[].concat(p).sort(function(){return Math.random()-0.5;}).slice(0,Math.min(pickCount,p.length));
  var c=document.getElementById('cards');
  c.innerHTML='';
  picked.forEach(function(item,i){
    var s=catStyle(item.category);
    var div=document.createElement('div');
    div.className='prompt-card';
    div.innerHTML=
      '<div class="card-accent" style="background:'+s.accent+'"></div>'+
      '<div class="card-num">Prompt '+(i+1)+' of '+picked.length+'</div>'+
      '<div class="card-text">\u201C'+renderMarkdown(item.prompt)+'\u201D</div>'+
      '<span class="card-tag" style="background:'+s.tag+';color:'+s.text+'">'+esc(item.category)+'</span>';
    c.appendChild(div);
  });
  document.getElementById('pickLabel').textContent='Pick Again \u21BB';
}

// ── Forget saved sheet ────────────────────────────────────────────────────────
function forgetSheet(){
  try { localStorage.removeItem('journal_sheet_url'); } catch(e){}
  document.getElementById('sheetUrl').value='';
  document.getElementById('mainUI').classList.remove('show');
  document.getElementById('emptyState').style.display='';
  document.getElementById('status').className='status';
  document.getElementById('errBox').classList.remove('show');
  clearLog();
  allPrompts=[];categories=[];
}

// ── Auto-load on startup ──────────────────────────────────────────────────────
window.addEventListener('DOMContentLoaded', function(){
  try {
    var saved = localStorage.getItem('journal_sheet_url');
    if(saved){
      document.getElementById('sheetUrl').value = saved;
      loadSheet();
    }
  } catch(e){}
});
</script>
